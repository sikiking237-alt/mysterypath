import React, { useState, useEffect, useCallback, useRef } from 'react';
import {
  Plus,
  Trash2,
  X,
  RefreshCw,
  Upload,
  Edit2,
  Star,
  Clock,
  Layers,
  Search,
  Filter,
  Grid3x3,
  List,
  ChevronDown,
  Sparkles,
  BookOpen,
  Users,
  Calendar,
  CheckCircle,
  AlertCircle,
  Loader2,
  Eye,
  MoreVertical,
  Copy,
  Archive,
  FileText,
  ArrowUpRight,
  ChevronRight,
  ChevronLeft,
  Check,
  AlertTriangle,
  Info,
  Target,
  ListChecks,
  Image,
  Rocket,
} from 'lucide-react';
import { apiCall, apiEndpoints } from './config/apiConfig';
import {
  useGetInstructorCoursesQuery,
  useCreateCourseMutation,
  useUpdateCourseMutation,
  useDeleteCourseMutation,
  useUploadImageMutation,
} from '../features/courses/coursesApi';

const ManageCourses = ({ darkMode }) => {
  const [courses, setCourses] = useState([]);
  const [loading, setLoading] = useState(true);
  const { data: coursesData = [], isLoading, isFetching, refetch } = useGetInstructorCoursesQuery();
  const [createCourse, { isLoading: isCreating }] = useCreateCourseMutation();
  const [updateCourse, { isLoading: isUpdating }] = useUpdateCourseMutation();
  const [deleteCourse] = useDeleteCourseMutation();
  const [uploadImage, { isLoading: uploadingImage }] = useUploadImageMutation();

  const [showAddModal, setShowAddModal] = useState(false);
  const [showEditModal, setShowEditModal] = useState(false);
  const [selectedCourse, setSelectedCourse] = useState(null);
  const [notification, setNotification] = useState(null);
  const [imagePreview, setImagePreview] = useState(null);
  const [editImagePreview, setEditImagePreview] = useState(null);
  const [saving, setSaving] = useState(false);
  const [viewMode, setViewMode] = useState("grid");
  const [selectedTab, setSelectedTab] = useState("all");
  const [currentStep, setCurrentStep] = useState(1);
  const [completedSteps, setCompletedSteps] = useState({});
  const [searchTerm, setSearchTerm] = useState("");
  const [selectedCategory, setSelectedCategory] = useState("All");
  const [currency, setCurrency] = useState('USD');

  const fileInputRef = useRef(null);
  const editFileInputRef = useRef(null);

  const [newCourse, setNewCourse] = useState({
    title: "",
    subtitle: "",
    description: "",
    level: "Beginner",
    category: "Development",
    image_url: "",
    price: 0,
    duration: "",
    whatYouWillLearn: [],
    requirements: [],
    targetAudience: [],
    isPublished: false,
    isFeatured: false,
    xpReward: 100,
  });

  // Wizard steps configuration
  const steps = [
    {
      id: 1,
      title: "Basic Info",
      icon: BookOpen,
      description: "Course title, description, and category",
    },
    {
      id: 2,
      title: "Content",
      icon: FileText,
      description: "Learning outcomes and requirements",
    },
    {
      id: 3,
      title: "Media",
      icon: Image,
      description: "Upload course image",
    },
    {
      id: 4,
      title: "Pricing & Publish",
      icon: Rocket,
      description: "Set price and publish",
    },
  ];

  // Update courses when RTK Query data changes
  useEffect(() => {
    if (coursesData) {
      setCourses(coursesData);
      setLoading(false);
    }
  }, [coursesData]);

  // Fetch settings
  useEffect(() => {
    fetchSettings();
  }, []);

  const fetchSettings = async () => {
    try {
      const response = await apiCall(apiEndpoints.admin.settings, { method: 'GET' });
      if (response.settings && response.settings.currency) {
        setCurrency(response.settings.currency);
      }
    } catch (err) {
      console.error('Error fetching settings:', err);
    }
  };

  const showNotification = (message, type = "success") => {
    setNotification({ message, type });
    setTimeout(() => setNotification(null), 3000);
  };

  // Validate current step
  const validateStep = (step) => {
    const errors = [];
    switch (step) {
      case 1:
        if (!newCourse.title.trim()) errors.push("Course title is required");
        if (!newCourse.description.trim()) errors.push("Course description is required");
        if (!newCourse.category) errors.push("Category is required");
        if (!newCourse.level) errors.push("Level is required");
        break;
      case 2:
        if (newCourse.whatYouWillLearn.length === 0) {
          errors.push("Add at least one learning outcome");
        }
        break;
      case 3:
        if (!newCourse.image_url) {
          errors.push("Course image is required");
        }
        break;
      case 4:
        // Pricing is optional
        break;
      default:
        break;
    }
    return errors;
  };

  const isStepValid = (step) => {
    return validateStep(step).length === 0;
  };

  const goToNextStep = () => {
    const errors = validateStep(currentStep);
    if (errors.length > 0) {
      showNotification(errors[0], "error");
      return;
    }
    setCompletedSteps({ ...completedSteps, [currentStep]: true });
    if (currentStep < steps.length) {
      setCurrentStep(currentStep + 1);
    }
  };

  const goToPreviousStep = () => {
    if (currentStep > 1) {
      setCurrentStep(currentStep - 1);
    }
  };

  const goToStep = (step) => {
    if (step <= currentStep || completedSteps[step]) {
      setCurrentStep(step);
    }
  };

  const resetWizard = () => {
    setCurrentStep(1);
    setCompletedSteps({});
    setNewCourse({
      title: "",
      subtitle: "",
      description: "",
      level: "Beginner",
      category: "Development",
      image_url: "",
      price: 0,
      duration: "",
      whatYouWillLearn: [],
      requirements: [],
      targetAudience: [],
      isPublished: false,
      isFeatured: false,
      xpReward: 100,
    });
    setImagePreview(null);
  };

  const handleImageSelect = async (e, isEdit = false) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onloadend = () => {
      if (isEdit) {
        setEditImagePreview(reader.result);
      } else {
        setImagePreview(reader.result);
      }
    };
    reader.readAsDataURL(file);

    try {
      const formData = new FormData();
      formData.append("file", file);
      
      const result = await uploadImage(formData).unwrap();
      if (result.success && result.image_url) {
        if (isEdit) {
          setSelectedCourse({ ...selectedCourse, image_url: result.image_url });
        } else {
          setNewCourse({ ...newCourse, image_url: result.image_url });
        }
      }
    } catch (error) {
      showNotification("Image upload failed", "error");
    }
  };

  const handleCreateCourse = async () => {
    // Validate all steps
    for (let step = 1; step <= steps.length; step++) {
      const errors = validateStep(step);
      if (errors.length > 0) {
        setCurrentStep(step);
        showNotification(errors[0], "error");
        return;
      }
    }

    setSaving(true);
    try {
      await createCourse({
        ...newCourse,
        title: newCourse.title.trim(),
        subtitle: newCourse.subtitle.trim(),
        description: newCourse.description.trim(),
      }).unwrap();
      
      showNotification("✅ Course created successfully!");
      setShowAddModal(false);
      resetWizard();
      // The list will refetch automatically due to tag invalidation
    } catch (error) {
      showNotification(error?.data?.error || "Error creating course", "error");
    } finally {
      setSaving(false);
    }
  };

  const handleUpdateCourse = async () => {
    if (!selectedCourse.title.trim()) {
      showNotification("Please enter course title", "error");
      return;
    }

    setSaving(true);
    try {
      await updateCourse({
        id: selectedCourse.id,
        ...selectedCourse,
      }).unwrap();
      
      showNotification("✅ Course updated successfully!");
      setShowEditModal(false);
      // The list will refetch automatically due to tag invalidation
    } catch (error) {
      showNotification(error?.data?.error || "Error updating course", "error");
    } finally {
      setSaving(false);
    }
  };

  const handleDeleteCourse = async (courseId) => {
    if (!window.confirm("Delete this course permanently?")) return;
    try {
      await deleteCourse(courseId).unwrap();
      showNotification("✅ Course deleted");
      // The list will refetch automatically due to tag invalidation
    } catch (error) {
      showNotification(error?.data?.error || "Error deleting", "error");
    }
  };

  const handleEditClick = (course) => {
    setSelectedCourse({ ...course });
    setEditImagePreview(course.image_url);
    setShowEditModal(true);
  };

  const handleRefresh = () => {
    refetch();
  };

  const levels = ["Beginner", "Intermediate", "Advanced", "Expert"];
  const categories = [
    "Development",
    "Data Science",
    "Design",
    "Cloud",
    "Marketing",
    "Business",
    "Finance",
    "Health",
  ];

  // Filter courses
  const filteredCourses = courses.filter((course) => {
    const matchesSearch =
      course.title.toLowerCase().includes(searchTerm.toLowerCase()) ||
      course.description?.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesCategory =
      selectedCategory === "All" || course.category === selectedCategory;
    const matchesTab =
      selectedTab === "all" ||
      (selectedTab === "published" && course.isPublished) ||
      (selectedTab === "draft" && !course.isPublished);
    return matchesSearch && matchesCategory && matchesTab;
  });

  const stats = {
    total: courses.length,
    published: courses.filter((c) => c.isPublished).length,
    draft: courses.filter((c) => !c.isPublished).length,
    totalStudents: courses.reduce((acc, c) => acc + (c.students || 0), 0),
  };

  if (isLoading && courses.length === 0) {
    return (
      <div className="flex flex-col items-center justify-center h-96">
        <Loader2 className="w-12 h-12 text-purple-500 animate-spin" />
        <p className="mt-4 text-gray-500 dark:text-gray-400 font-medium">
          Loading your curriculum...
        </p>
      </div>
    );
  }

  return (
    <div className="min-h-screen p-6 bg-gray-50 dark:bg-gray-900">
      {/* Notification */}
      {notification && (
        <div
          className={`fixed top-24 left-1/2 transform -translate-x-1/2 z-50 px-6 py-3 rounded-2xl text-white text-sm font-medium flex items-center gap-2 shadow-2xl ${
            notification.type === "error"
              ? "bg-red-500"
              : "bg-gradient-to-r from-emerald-500 to-teal-500"
          }`}
        >
          {notification.type === "error" ? (
            <AlertCircle size={18} />
          ) : (
            <CheckCircle size={18} />
          )}
          {notification.message}
        </div>
      )}

      {/* Header */}
      <div className="flex flex-col lg:flex-row lg:items-end justify-between gap-6 mb-8">
        <div>
          <div className="flex items-center gap-3 mb-2">
            <div className="px-3 py-1 rounded-lg bg-purple-100 dark:bg-purple-900/40 text-purple-700 dark:text-purple-300 text-xs font-bold uppercase tracking-wider border border-purple-200 dark:border-purple-800">
              Content Management
            </div>
            <div className="flex items-center gap-1 text-xs text-gray-400">
              <span className="w-1.5 h-1.5 rounded-full bg-emerald-400"></span>
              {stats.published} Published
            </div>
          </div>
          <h1
            className={`text-4xl font-black tracking-tight ${darkMode ? "text-white" : "text-gray-900"}`}
          >
            Curriculum Library
          </h1>
          <p
            className={`text-base mt-2 max-w-2xl ${darkMode ? "text-gray-400" : "text-gray-500"}`}
          >
            Manage your courses, track student feedback, and update your
            educational content in real-time.
          </p>
        </div>
        <div className="flex items-center gap-3">
          <button
            onClick={handleRefresh}
            disabled={isFetching}
            className={`px-4 py-2.5 rounded-xl flex items-center gap-2 font-medium transition-all border ${
              darkMode
                ? "bg-gray-800 border-gray-700 text-gray-300 hover:bg-gray-700"
                : "bg-white border-gray-200 text-gray-600 hover:bg-gray-50 shadow-sm"
            }`}
          >
            <RefreshCw
              size={16}
              className={isFetching ? "animate-spin" : ""}
            />
            Refresh
          </button>
          <button
            onClick={() => {
              resetWizard();
              setShowAddModal(true);
            }}
            className="px-6 py-2.5 bg-gradient-to-r from-purple-600 to-indigo-600 text-white rounded-xl font-bold hover:shadow-lg hover:shadow-purple-500/25 hover:-translate-y-0.5 active:translate-y-0 transition-all flex items-center gap-2"
          >
            <Plus size={18} /> Create Course
          </button>
        </div>
      </div>

      {/* Stats Cards */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        {[
          { label: "Total Courses", value: stats.total, icon: BookOpen, color: "purple" },
          { label: "Published", value: stats.published, icon: CheckCircle, color: "emerald" },
          { label: "Drafts", value: stats.draft, icon: FileText, color: "amber" },
          { label: "Total Students", value: stats.totalStudents, icon: Users, color: "blue" },
        ].map((stat, idx) => (
          <div
            key={idx}
            className={`p-5 rounded-2xl border ${
              darkMode
                ? "bg-gray-800/50 border-gray-700"
                : "bg-white border-gray-100 shadow-sm"
            }`}
          >
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm font-medium text-gray-500 dark:text-gray-400">
                  {stat.label}
                </p>
                <p className="text-2xl font-black mt-1 dark:text-white">
                  {stat.value}
                </p>
              </div>
              <div
                className={`p-3 rounded-xl bg-${stat.color}-100 dark:bg-${stat.color}-900/30`}
              >
                <stat.icon
                  size={20}
                  className={`text-${stat.color}-600 dark:text-${stat.color}-400`}
                />
              </div>
            </div>
          </div>
        ))}
      </div>

      {/* Filters and Tabs */}
      <div className="flex flex-col md:flex-row gap-4 mb-8">
        <div className="relative flex-1">
          <Search
            className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400"
            size={18}
          />
          <input
            type="text"
            placeholder="Search your curriculum..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
            className={`w-full pl-10 pr-4 py-2.5 rounded-xl border ${
              darkMode
                ? "bg-gray-800/40 border-gray-700 text-white focus:border-purple-500"
                : "bg-white border-gray-200 text-gray-900 focus:border-purple-500"
            } focus:outline-none transition-all shadow-sm font-medium`}
          />
        </div>
        <div className="flex items-center gap-2">
          <Filter className="text-gray-400" size={18} />
          <select
            value={selectedCategory}
            onChange={(e) => setSelectedCategory(e.target.value)}
            className={`px-4 py-2.5 rounded-xl border ${
              darkMode
                ? "bg-gray-800/40 border-gray-700 text-white"
                : "bg-white border-gray-200 text-gray-600"
            } focus:outline-none focus:ring-2 focus:ring-purple-500/20 shadow-sm font-bold text-sm min-w-[160px]`}
          >
            <option value="All">All Categories</option>
            {categories.map((c) => (
              <option key={c} value={c}>
                {c}
              </option>
            ))}
          </select>
        </div>
        <div className="flex items-center gap-1 p-1 rounded-xl bg-gray-100 dark:bg-gray-800">
          <button
            onClick={() => setViewMode("grid")}
            className={`p-2 rounded-lg transition-all ${
              viewMode === "grid"
                ? "bg-white dark:bg-gray-700 shadow-sm"
                : "text-gray-500"
            }`}
          >
            <Grid3x3 size={18} />
          </button>
          <button
            onClick={() => setViewMode("list")}
            className={`p-2 rounded-lg transition-all ${
              viewMode === "list"
                ? "bg-white dark:bg-gray-700 shadow-sm"
                : "text-gray-500"
            }`}
          >
            <List size={18} />
          </button>
        </div>
      </div>

      {/* Tabs */}
      <div className="flex gap-1 mb-8 p-1 rounded-xl bg-gray-100 dark:bg-gray-800 w-fit">
        {[
          { id: "all", label: "All", count: stats.total },
          { id: "published", label: "Published", count: stats.published },
          { id: "draft", label: "Drafts", count: stats.draft },
        ].map((tab) => (
          <button
            key={tab.id}
            onClick={() => setSelectedTab(tab.id)}
            className={`px-4 py-2 rounded-lg text-sm font-medium transition-all ${
              selectedTab === tab.id
                ? "bg-white dark:bg-gray-700 shadow-sm dark:text-white"
                : "text-gray-500 dark:text-gray-400 hover:text-gray-700"
            }`}
          >
            {tab.label}{" "}
            <span className="text-xs text-gray-400 dark:text-gray-500">
              ({tab.count})
            </span>
          </button>
        ))}
      </div>

      {/* Course Grid/List */}
      {filteredCourses.length === 0 ? (
        <div
          className={`text-center py-24 rounded-3xl border-2 border-dashed ${
            darkMode
              ? "bg-gray-800/40 border-gray-700"
              : "bg-gray-50 border-gray-200"
          }`}
        >
          <div className="flex justify-center mb-4">
            <div className="p-6 rounded-full bg-purple-100 dark:bg-purple-900/30">
              <Layers size={48} className="text-purple-500" />
            </div>
          </div>
          <h3
            className={`text-xl font-black ${darkMode ? "text-white" : "text-gray-900"}`}
          >
            {searchTerm ? "No results found" : "No courses yet"}
          </h3>
          <p className="text-gray-500 mt-2 max-w-xs mx-auto">
            {searchTerm
              ? "Try adjusting your search or filters."
              : "Get started by building your first educational program."}
          </p>
          {!searchTerm && (
            <button
              onClick={() => {
                resetWizard();
                setShowAddModal(true);
              }}
              className="mt-6 px-6 py-3 bg-purple-600 text-white rounded-xl font-bold hover:bg-purple-700 transition"
            >
              Create Your First Course
            </button>
          )}
        </div>
      ) : viewMode === "grid" ? (
        <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          {filteredCourses.map((course) => (
            <CourseCard
              key={course.id}
              course={course}
              darkMode={darkMode}
              onEdit={handleEditClick}
              onDelete={handleDeleteCourse}
              currency={currency}
            />
          ))}
        </div>
      ) : (
        <div className="space-y-4">
          {filteredCourses.map((course) => (
            <CourseListItem
              key={course.id}
              course={course}
              darkMode={darkMode}
              onEdit={handleEditClick}
              onDelete={handleDeleteCourse}
              currency={currency}
            />
          ))}
        </div>
      )}

      {/* Create Course Modal - Keep your existing modal code */}
      {/* ... (the wizard modal code remains the same) ... */}

      {/* Edit Modal */}
      {showEditModal && selectedCourse && (
        <EditCourseModal
          isOpen={showEditModal}
          onClose={() => {
            setShowEditModal(false);
            setEditImagePreview(null);
          }}
          onSave={handleUpdateCourse}
          course={selectedCourse}
          setCourse={setSelectedCourse}
          imagePreview={editImagePreview}
          onImageSelect={(e) => handleImageSelect(e, true)}
          saving={saving}
          uploadingImage={uploadingImage}
          darkMode={darkMode}
          fileInputRef={editFileInputRef}
          categories={categories}
          levels={levels}
        />
      )}
    </div>
  );
};

// ========== STEP COMPONENTS ==========
// ... (Keep all the Step components - StepBasicInfo, StepContent, StepMedia, StepPricing) ...

// ========== COURSE CARD COMPONENTS ==========
// ... (Keep CourseCard and CourseListItem) ...

// ========== EDIT MODAL ==========
// ... (Keep EditCourseModal) ...

export default ManageCourses;